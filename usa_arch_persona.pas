 PROCEDURE BUSCAR_ARCH_NOM_P(VAR ARCH:T_ARCHIVO_PROP;VAR BUSCADO:STRING;VAR POS:BYTE; VAR ENC:BOOLEAN);
 VAR
   X:T_DATO_PROP;
   NOM:STRING;
 BEGIN
   SEEK(ARCH,0);
   WHILE NOT(EOF(ARCH)) DO
   BEGIN
         READ(ARCH,X);
         NOM:=CONCAT(X.AP+' '+X.NOM);
         IF (NOM = BUSCADO) AND (X.ESTADO=TRUE) THEN
         BEGIN
           POS:= FILEPOS(ARCH)-1;
           ENC:=TRUE;
         END;
   END
 END;

 PROCEDURE AGREGAR_PERSONA(VAR ARCH:T_ARCHIVO_PROP; VAR X:T_DATO_PROP);
 BEGIN
   SEEK(ARCH, FILESIZE(ARCH));
   WRITE(ARCH,X);
 END;

END.
